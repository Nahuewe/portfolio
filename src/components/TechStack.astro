---
import { useTranslations, type Lang } from "@/i18n/utils"

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const groups = {
  [t("stack.specialization")]: [
    "React",
    "Next.js",
    "Astro",
    "TypeScript",
    "Laravel"
  ],
  [t("stack.infrastructure")]: [
    "Docker",
    "GitHub Actions",
    "Linux",
    "CI/CD"
  ],
  [t("stack.data")]: [
    "PostgreSQL",
    "MySQL",
    "Supabase",
    "TanStack Query"
  ]
}
---

{
  Object.entries(groups).map(([title, items]) => (
    <div class="mb-8">
      <h3 class="mb-3 text-xl font-bold">{title}</h3>

      <div class="flex flex-wrap gap-2">
        {
          items.map(item => (
            <span class="rounded-full border px-3 py-2">
              {item}
            </span>
          ))
        }
      </div>
    </div>
  ))
}
