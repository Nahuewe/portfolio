---
import type { Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const target = lang === "es" ? "EN" : "ES";
const ariaLabel = lang === "es" ? "Switch to English" : "Cambiar a español";
---

<button
  type="button"
  class="lang-toggle inline-flex size-8 items-center justify-center rounded-full border border-gray-300/60 text-xs font-semibold text-gray-700 transition-colors hover:border-violet-400 hover:text-violet-500 dark:border-gray-600/60 dark:text-gray-200 dark:hover:border-violet-400 dark:hover:text-violet-400"
  aria-label={ariaLabel}
  data-lang={lang}
>
  {target}
</button>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLButtonElement>(".lang-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        const currentLang = button.dataset.lang;
        const { pathname, search, hash } = window.location;

        const nextPath =
          currentLang === "es"
            ? `/en${pathname === "/" ? "" : pathname}`
            : pathname.replace(/^\/en/, "") || "/";

        window.location.href = `${nextPath}${search}${hash}`;
      });
    });
  });
</script>
