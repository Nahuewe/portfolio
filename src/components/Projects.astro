---
import GitHub from "./icons/GitHub.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"

const PROJECTS = projectsData as Array<{
  title: string
  description: string
  tags: string[]
  link?: string
  github?: string
}>
---

{PROJECTS.length === 0 ? (
  <p class="mt-8 text-gray-500 dark:text-gray-400 italic">Próximamente...</p>
) : (
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {
      PROJECTS.map(({ title, description, tags, link, github }) => (
        <article class="group flex flex-col rounded-xl border border-gray-200 bg-white/60 p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_-10px_rgba(251,191,36,0.2)] dark:border-gray-800 dark:bg-gray-900/40 dark:hover:border-violet-400/30">
          <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100">
            {title}
          </h3>

          <ul class="mt-3 flex flex-row flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">
                {tag}
              </li>
            ))}
          </ul>

          <p class="mt-4 text-pretty text-gray-700 dark:text-gray-400">{description}</p>

          {(github || link) && (
            <footer class="mt-5 flex items-center gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-5" />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <ExternalLink class="size-4" />
                  Preview
                </LinkButton>
              )}
            </footer>
          )}
        </article>
      ))
    }
  </div>
)}
