---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { useTranslations, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === "es" ? "" : "/en";

const navItems = [
  {
    title: t("nav.services"),
    label: "servicios",
    url: `${base}/#servicios`,
  },
  {
    title: t("nav.experience"),
    label: "experiencia",
    url: `${base}/#experiencia`,
  },
  {
    title: t("nav.stack"),
    label: "stack",
    url: `${base}/#stack`,
  },
  {
    title: t("nav.projects"),
    label: "proyectos",
    url: `${base}/#proyectos`,
  },
  {
    title: t("nav.about"),
    label: "sobre-mi",
    url: `${base}/#sobre-mi`,
  },
];
---

<header class="fixed top-4 z-50 w-full px-4">
  <div class="mx-auto max-w-6xl">

    <!-- MOBILE -->
    <div
      class="
        md:hidden
        flex
        items-center
        justify-between
        rounded-2xl
        border
        border-gray-200/20
        bg-white/80
        dark:bg-gray-900/80
        backdrop-blur-xl
        shadow-lg
        px-4
        py-3
      "
    >
      <button
        id="menu-toggle"
        class="
          text-sm
          font-medium
          text-gray-700
          dark:text-gray-200
          cursor-pointer
        "
      >
        ☰ {t("nav.menu")}
      </button>

      <div class="flex items-center gap-2">
        <LanguageToggle lang={lang} />
        <ThemeToggle />
      </div>
    </div>

    <!-- MOBILE MENU -->
    <div
      id="mobile-menu"
      class="
        hidden
        md:hidden
        mt-2
        rounded-2xl
        border
        border-gray-200/20
        bg-white/95
        dark:bg-gray-900/95
        backdrop-blur-xl
        shadow-xl
        p-4
      "
    >
      <div class="flex flex-col gap-2">
        {
          navItems.map((link) => (
            <a
              href={link.url}
              class="
                rounded-xl
                px-4
                py-3
                transition-colors
                hover:bg-violet-500/10
                hover:text-violet-500
              "
            >
              {link.title}
            </a>
          ))
        }

        <a
          href={`${base}/#contacto`}
          class="
            mt-2
            rounded-xl
            bg-violet-600
            px-4
            py-3
            text-center
            font-semibold
            text-white
            transition-all
            hover:bg-violet-500
            cursor-pointer
          "
        >
          {t("nav.contact")}
        </a>
      </div>
    </div>

    <!-- DESKTOP -->
    <nav
      class="
        hidden
        md:flex
        header-nav
        items-center
        justify-center
        gap-1
        mx-auto
        w-fit
        rounded-full
        px-3
        py-2
      "
    >
      {
        navItems.map((link) => (
          <a
            class="
              nav-link
              relative
              px-3
              py-2
              rounded-full
              text-sm
              transition-colors
              duration-200
              hover:text-violet-500
              dark:hover:text-violet-400
            "
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }

      <a
        href={`${base}/#contacto`}
        class="
          ml-2
          rounded-full
          bg-violet-600
          px-4
          py-2
          text-sm
          font-semibold
          text-white
          transition-all
          hover:bg-violet-500
          hover:scale-105
          cursor-pointer
        "
      >
        {t("nav.contact")}
      </a>

      <div class="ml-2 pl-2 flex items-center gap-2 border-l border-gray-300/30 dark:border-white/10">
        <LanguageToggle lang={lang} />
        <ThemeToggle />
      </div>
    </nav>

  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuButton = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    menuButton?.addEventListener("click", () => {
      mobileMenu?.classList.toggle("hidden");
    });

    const sections = document.querySelectorAll("section");
    const navItems = document.querySelectorAll(".nav-link");

    const callback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        navItems.forEach((item) => {
          const active =
            item.getAttribute("aria-label") === entry.target.id;

          item.classList.toggle(
            "text-violet-500",
            active,
          );

          item.classList.toggle(
            "dark:text-violet-400",
            active,
          );

          item.classList.toggle(
            "bg-violet-500/10",
            active,
          );

          item.classList.toggle(
            "font-semibold",
            active,
          );
        });
      });
    };

    const observer = new IntersectionObserver(callback, {
      threshold: 0.35,
    });

    sections.forEach((section) => {
      observer.observe(section);
    });
  });
</script>

<style>
  .header-nav {
    animation: nav-appear 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;

    @apply
      bg-white/70
      dark:bg-gray-900/70
      backdrop-blur-xl
      border
      border-gray-200/20
      dark:border-white/10
      shadow-xl;
  }

  @keyframes nav-appear {
    0% {
      @apply
        bg-transparent
        border-transparent
        shadow-none;
    }

    100% {
      @apply
        backdrop-blur-xl
        shadow-xl;
    }
  }
</style>
