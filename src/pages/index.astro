---
import Layout from "@/layouts/Layout.astro";
import AboutMe from "@/components/AboutMe.astro";
import Briefcase from "@/components/icons/Briefcase.astro";
import CodeDots from "@/components/icons/CodeDots.astro";
import Experience from "@/components/Experience.astro";
import UserHeart from "@/components/icons/UserHeart.astro";
import Projects from "@/components/Projects.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import Hero from "@/components/Hero.astro";
import TitleSection from "@/components/TitleSection.astro";
import Services from "@/components/Services.astro";
import TechStack from "@/components/TechStack.astro";
---

<Layout
  title="Nahuel Soria Parodi - Desarrollador FullStack"
  description="Desarrollador FullStack con más de 4 años de experiencia en React, TypeScript, Next.js y Laravel. Especializado en plataformas administrativas, dashboards y sistemas en tiempo real."
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-16">
      <Hero />
    </SectionContainer>

    <div class="space-y-16">
      <SectionContainer id="servicios">
        <TitleSection>
          <CodeDots class="size-7" />
          Lo que hago
        </TitleSection>

        <Services />
      </SectionContainer>

      <SectionContainer id="experiencia">
        <TitleSection>
          <Briefcase class="size-8" />
          Experiencia laboral
        </TitleSection>

        <Experience />
      </SectionContainer>

      <SectionContainer id="stack">
        <TitleSection>
          <CodeDots class="size-7" />
          Stack principal
        </TitleSection>

        <TechStack />
      </SectionContainer>

      <SectionContainer id="proyectos">
        <TitleSection>
          <CodeDots class="size-7" />
          Proyectos destacados
        </TitleSection>

        <Projects />
      </SectionContainer>

      <SectionContainer id="actualmente">
        <div
          class="rounded-3xl border border-neutral-800
          bg-gradient-to-br from-neutral-900/80
          to-neutral-950 p-8 md:p-10"
        >
          <span
            class="inline-flex rounded-full
            border border-violet-500/30
            bg-violet-500/10
            px-3 py-1
            text-sm font-medium
            text-violet-300"
          >
            Actualmente
          </span>

          <h2 class="mt-4 text-3xl font-bold">En qué estoy trabajando</h2>

          <div class="mt-8 grid gap-4 md:grid-cols-2">
            <div class="rounded-xl border border-neutral-800 p-5">
              Mejorando plataformas municipales
            </div>

            <div class="rounded-xl border border-neutral-800 p-5">
              Desarrollando aplicaciones con Astro
            </div>

            <div class="rounded-xl border border-neutral-800 p-5">
              Explorando IA aplicada al desarrollo web
            </div>

            <div class="rounded-xl border border-neutral-800 p-5">
              Migrando y mejorando sistemas a TypeScript y Next.js
            </div>
          </div>
        </div>
      </SectionContainer>

      <!-- SOBRE MI -->
      <SectionContainer id="sobre-mi">
        <TitleSection>
          <UserHeart class="size-8" />
          Sobre mí
        </TitleSection>

        <AboutMe />
      </SectionContainer>

      <SectionContainer id="contacto">
        <div
          class="rounded-3xl border border-violet-500/20
    bg-violet-500/10 p-10 text-center"
        >
          <h2 class="text-3xl font-bold">¿Trabajamos juntos?</h2>

          <p class="mt-4 text-neutral-500 dark:text-neutral-400">
            Estoy disponible para nuevos proyectos, desarrollo de plataformas
            administrativas, dashboards e integraciones.
          </p>

          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a
              href="mailto:nahuelsoriap@gmail.com"
              class="cursor-pointer rounded-xl bg-violet-500 px-6 py-3 font-semibold text-white transition hover:scale-105"
            >
              Enviar Email
            </a>

            <a
              href="https://linkedin.com/in/nahuelsoriaparodi"
              target="_blank"
              class="cursor-pointer rounded-xl border px-6 py-3 hover:scale-105 transition border-blue-500 text-blue-500 hover:bg-blue-500 hover:text-white"
            >
              LinkedIn
            </a>
          </div>
        </div>
      </SectionContainer>
    </div>
  </main>
</Layout>
